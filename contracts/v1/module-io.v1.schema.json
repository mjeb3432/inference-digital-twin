{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inference-digital-twin.local/contracts/v1/module-io.v1.schema.json",
  "title": "ModuleIOV1",
  "description": "Versioned envelopes exchanged between orchestrator and worker modules.",
  "oneOf": [
    {
      "$ref": "#/$defs/module_input"
    },
    {
      "$ref": "#/$defs/module_output"
    }
  ],
  "$defs": {
    "module_name": {
      "type": "string",
      "enum": [
        "hardware",
        "interconnect",
        "runtime",
        "orchestration",
        "energy"
      ]
    },
    "error_class": {
      "type": "string",
      "enum": [
        "validation",
        "data_missing",
        "calibration_out_of_range",
        "compute_timeout",
        "internal"
      ]
    },
    "metric_name": {
      "type": "string",
      "enum": [
        "ttft_ms",
        "tpot_ms",
        "tps",
        "concurrency",
        "mfu_utilization_pct",
        "gpu_utilization_pct",
        "carbon_kg_per_hour",
        "renewable_share_pct",
        "cost_usd_per_hour",
        "power_watts"
      ]
    },
    "metric_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "confidence_interval": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lower",
            "upper"
          ],
          "properties": {
            "lower": {
              "type": "number"
            },
            "upper": {
              "type": "number"
            }
          }
        }
      }
    },
    "module_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "stage_id"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._:-]{3,128}$"
        },
        "stage_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._:-]{3,128}$"
        }
      }
    },
    "module_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "module_name",
        "module_version",
        "scenario_hash",
        "artifact_ids",
        "requested_metrics",
        "payload",
        "trace",
        "created_at"
      ],
      "properties": {
        "contract": {
          "const": "ModuleInput.v1"
        },
        "module_name": {
          "$ref": "#/$defs/module_name"
        },
        "module_version": {
          "type": "string",
          "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
        },
        "scenario_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "artifact_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "requested_metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric_name"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "upstream_outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "module_name",
              "module_version",
              "output_hash"
            ],
            "properties": {
              "module_name": {
                "$ref": "#/$defs/module_name"
              },
              "module_version": {
                "type": "string",
                "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
              },
              "output_hash": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          }
        },
        "payload": {
          "type": "object"
        },
        "trace": {
          "$ref": "#/$defs/module_trace"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "module_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "module_name",
        "module_version",
        "scenario_hash",
        "artifact_ids",
        "status",
        "metrics",
        "timings",
        "trace",
        "created_at"
      ],
      "properties": {
        "contract": {
          "const": "ModuleOutput.v1"
        },
        "module_name": {
          "$ref": "#/$defs/module_name"
        },
        "module_version": {
          "type": "string",
          "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
        },
        "scenario_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "artifact_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "partial",
            "failed"
          ]
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ttft_ms": {
              "$ref": "#/$defs/metric_estimate"
            },
            "tpot_ms": {
              "$ref": "#/$defs/metric_estimate"
            },
            "tps": {
              "$ref": "#/$defs/metric_estimate"
            },
            "concurrency": {
              "$ref": "#/$defs/metric_estimate"
            },
            "mfu_utilization_pct": {
              "$ref": "#/$defs/metric_estimate"
            },
            "gpu_utilization_pct": {
              "$ref": "#/$defs/metric_estimate"
            },
            "carbon_kg_per_hour": {
              "$ref": "#/$defs/metric_estimate"
            },
            "renewable_share_pct": {
              "$ref": "#/$defs/metric_estimate"
            },
            "cost_usd_per_hour": {
              "$ref": "#/$defs/metric_estimate"
            },
            "power_watts": {
              "$ref": "#/$defs/metric_estimate"
            }
          }
        },
        "timings": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "queue_wait_ms",
            "compute_ms",
            "total_ms"
          ],
          "properties": {
            "queue_wait_ms": {
              "type": "number",
              "minimum": 0
            },
            "compute_ms": {
              "type": "number",
              "minimum": 0
            },
            "total_ms": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "error_class",
            "message"
          ],
          "properties": {
            "error_class": {
              "$ref": "#/$defs/error_class"
            },
            "message": {
              "type": "string",
              "minLength": 1,
              "maxLength": 5000
            },
            "details": {
              "type": "object"
            }
          }
        },
        "trace": {
          "$ref": "#/$defs/module_trace"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
